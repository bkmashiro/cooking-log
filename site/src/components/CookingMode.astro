---
interface Ingredient {
  name: string;
  amount: number | null;
  unit: string;
  scale: string;
  note: string;
}

interface Props {
  ingredients: Ingredient[];
  steps: string[];
  dishName: string;
  lang: 'zh' | 'en' | 'ja';
  baseServings: number;
}

const { ingredients, steps, dishName, lang, baseServings } = Astro.props;

const i18nStrings = {
  zh: {
    enterCooking: '🍳 进入烹饪模式',
    prepMode: '备菜模式',
    cookMode: '烹饪模式',
    prepReady: '已备好',
    startCooking: '开始烹饪 →',
    prev: '← 上一步',
    next: '下一步 →',
    done: '完成！',
    exit: '✕',
    step: '步骤',
    of: '/',
    timer: '计时器',
    start: '开始',
    pause: '暂停',
    reset: '重置',
    min: '分钟',
    custom: '自定义',
    timerDone: '时间到！',
    allPrepped: '所有食材已备好',
    tapToExpand: '⏱ 计时器',
    toTaste: '适量',
  },
  en: {
    enterCooking: '🍳 Enter Cooking Mode',
    prepMode: 'Prep Mode',
    cookMode: 'Cook Mode',
    prepReady: 'prepped',
    startCooking: 'Start Cooking →',
    prev: '← Prev',
    next: 'Next →',
    done: 'Done!',
    exit: '✕',
    step: 'Step',
    of: '/',
    timer: 'Timer',
    start: 'Start',
    pause: 'Pause',
    reset: 'Reset',
    min: 'min',
    custom: 'Custom',
    timerDone: "Time's up!",
    allPrepped: 'All ingredients prepped!',
    tapToExpand: '⏱ Timer',
    toTaste: 'to taste',
  },
  ja: {
    enterCooking: '🍳 調理モードへ',
    prepMode: '下準備モード',
    cookMode: '調理モード',
    prepReady: '準備完了',
    startCooking: '調理開始 →',
    prev: '← 前へ',
    next: '次へ →',
    done: '完成！',
    exit: '✕',
    step: 'ステップ',
    of: '/',
    timer: 'タイマー',
    start: '開始',
    pause: '一時停止',
    reset: 'リセット',
    min: '分',
    custom: 'カスタム',
    timerDone: '時間切れ！',
    allPrepped: '食材の準備完了！',
    tapToExpand: '⏱ タイマー',
    toTaste: '適量',
  },
}[lang];

const ingredientsJson = JSON.stringify(ingredients);
const stepsJson = JSON.stringify(steps);
const i18nJson = JSON.stringify(i18nStrings);
---

<!-- Entry button -->
<div class="cooking-mode-entry">
  <button id="cooking-mode-open" class="cooking-mode-btn">
    {i18nStrings.enterCooking}
  </button>
</div>

<!-- Full-screen overlay -->
<div id="cooking-mode-overlay" class="cm-overlay" hidden aria-modal="true" role="dialog">

  <!-- PREP MODE -->
  <div id="cm-prep" class="cm-screen">
    <header class="cm-header">
      <span class="cm-dish-name" id="cm-prep-dish-name"></span>
      <span class="cm-mode-badge cm-badge-prep" id="cm-prep-badge"></span>
      <button class="cm-exit-btn" id="cm-exit-prep" aria-label="Exit"></button>
    </header>

    <div class="cm-prep-body">
      <div class="cm-prep-progress" id="cm-prep-progress">0 / 0 <span id="cm-prep-ready-label"></span></div>
      <ul class="cm-ingredient-list" id="cm-ingredient-list"></ul>
    </div>

    <footer class="cm-footer">
      <button class="cm-action-btn" id="cm-start-cook"></button>
    </footer>
  </div>

  <!-- COOK MODE -->
  <div id="cm-cook" class="cm-screen" hidden>
    <header class="cm-header">
      <span class="cm-dish-name" id="cm-cook-dish-name"></span>
      <div class="cm-cook-meta">
        <span class="cm-mode-badge cm-badge-cook" id="cm-cook-badge"></span>
        <span class="cm-step-counter" id="cm-step-counter"></span>
      </div>
      <button class="cm-exit-btn" id="cm-exit-cook" aria-label="Exit"></button>
    </header>

    <!-- Progress bar -->
    <div class="cm-progress-bar-wrap">
      <div class="cm-progress-bar" id="cm-progress-bar"></div>
    </div>

    <div class="cm-cook-layout">
      <!-- Steps panel -->
      <div class="cm-steps-panel" id="cm-steps-panel">
        <div class="cm-steps-container" id="cm-steps-container">
          <!-- Steps rendered by JS -->
        </div>
      </div>

      <!-- Timer panel -->
      <aside class="cm-timer-panel" id="cm-timer-panel">
        <div class="cm-timer-header" id="cm-timer-toggle-btn">
          <span id="cm-timer-label"></span>
        </div>
        <div class="cm-timer-body" id="cm-timer-body">
          <div class="cm-timer-display" id="cm-timer-display">00:00</div>
          <div class="cm-timer-presets">
            <button class="cm-preset-btn" data-mins="1">1m</button>
            <button class="cm-preset-btn" data-mins="3">3m</button>
            <button class="cm-preset-btn" data-mins="5">5m</button>
            <button class="cm-preset-btn" data-mins="10">10m</button>
          </div>
          <div class="cm-timer-custom">
            <input type="number" id="cm-timer-custom-input" min="1" max="99" placeholder="—" />
            <span id="cm-timer-min-label"></span>
          </div>
          <div class="cm-timer-controls">
            <button class="cm-timer-btn cm-btn-start" id="cm-timer-start"></button>
            <button class="cm-timer-btn cm-btn-reset" id="cm-timer-reset"></button>
          </div>
        </div>
      </aside>
    </div>

    <footer class="cm-footer cm-cook-footer">
      <button class="cm-nav-btn" id="cm-prev-btn"></button>
      <span class="cm-step-display" id="cm-step-display"></span>
      <button class="cm-nav-btn cm-nav-next" id="cm-next-btn"></button>
    </footer>
  </div>

</div>

<script define:vars={{ ingredientsJson, stepsJson, i18nJson, dishName, baseServings }}>
(function() {
  const ingredients = JSON.parse(ingredientsJson);
  const steps = JSON.parse(stepsJson);
  const T = JSON.parse(i18nJson);

  // ── DOM refs ──────────────────────────────────────────────────
  const overlay      = document.getElementById('cooking-mode-overlay');
  const openBtn      = document.getElementById('cooking-mode-open');
  const prepScreen   = document.getElementById('cm-prep');
  const cookScreen   = document.getElementById('cm-cook');

  // Prep
  const prepDishName  = document.getElementById('cm-prep-dish-name');
  const prepBadge     = document.getElementById('cm-prep-badge');
  const prepProgress  = document.getElementById('cm-prep-progress');
  const prepReadyLbl  = document.getElementById('cm-prep-ready-label');
  const ingredientList= document.getElementById('cm-ingredient-list');
  const startCookBtn  = document.getElementById('cm-start-cook');
  const exitPrepBtn   = document.getElementById('cm-exit-prep');

  // Cook
  const cookDishName  = document.getElementById('cm-cook-dish-name');
  const cookBadge     = document.getElementById('cm-cook-badge');
  const stepCounter   = document.getElementById('cm-step-counter');
  const stepsContainer= document.getElementById('cm-steps-container');
  const progressBar   = document.getElementById('cm-progress-bar');
  const prevBtn       = document.getElementById('cm-prev-btn');
  const nextBtn       = document.getElementById('cm-next-btn');
  const stepDisplay   = document.getElementById('cm-step-display');
  const exitCookBtn   = document.getElementById('cm-exit-cook');

  // Timer
  const timerToggleBtn    = document.getElementById('cm-timer-toggle-btn');
  const timerBody         = document.getElementById('cm-timer-body');
  const timerDisplay      = document.getElementById('cm-timer-display');
  const timerCustomInput  = document.getElementById('cm-timer-custom-input');
  const timerStartBtn     = document.getElementById('cm-timer-start');
  const timerResetBtn     = document.getElementById('cm-timer-reset');
  const timerMinLabel     = document.getElementById('cm-timer-min-label');
  const timerLabel        = document.getElementById('cm-timer-label');

  // ── State ─────────────────────────────────────────────────────
  let currentStep = 0;
  let checkedCount = 0;
  let timerSeconds = 0;
  let timerTarget = 0;
  let timerRunning = false;
  let timerInterval = null;
  let timerExpired = false;
  let timerExpanded = true; // desktop always visible
  let swipeStartX = 0;
  let audioCtx = null;

  // ── Helpers ───────────────────────────────────────────────────
  function isMobile() {
    return window.innerWidth <= 768;
  }

  function boldify(text) {
    return text.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
  }

  function fmtTime(secs) {
    const m = Math.floor(secs / 60).toString().padStart(2, '0');
    const s = (secs % 60).toString().padStart(2, '0');
    return `${m}:${s}`;
  }

  function getScaledAmount(ing) {
    // Read current scaler value if available
    const scalerInput = document.getElementById('scaler-input');
    const servings = scalerInput ? parseFloat(scalerInput.value) || baseServings : baseServings;
    const mult = baseServings > 0 ? servings / baseServings : 1;

    if (ing.scale === 'to_taste') return T.toTaste;
    if (ing.scale === 'fixed' || ing.amount == null) {
      return ing.amount != null ? `${ing.amount}${ing.unit}` : T.toTaste;
    }

    const raw = ing.amount * mult;

    if (ing.scale === 'discrete') {
      const snapped = Math.max(0.5, Math.round(raw * 2) / 2);
      if (snapped === Math.floor(snapped)) return `${Math.floor(snapped)}${ing.unit}`;
      const w = Math.floor(snapped);
      return w === 0 ? `½${ing.unit}` : `${w}½${ing.unit}`;
    }

    // linear
    const FRACS = {0.25:'¼',0.5:'½',0.75:'¾',1.25:'1¼',1.5:'1½',1.75:'1¾',
                   2.25:'2¼',2.5:'2½',2.75:'2¾',3.25:'3¼',3.5:'3½',3.75:'3¾',
                   4.5:'4½',5.5:'5½'};
    for (const [fv, fs] of Object.entries(FRACS)) {
      if (Math.abs(raw - +fv) < 0.015) return `${fs}${ing.unit}`;
    }
    if (Math.abs(raw - Math.round(raw)) < 0.015) return `${Math.round(raw)}${ing.unit}`;
    if (raw >= 10) return `${Math.round(raw)}${ing.unit}`;
    return `${raw.toFixed(1).replace(/\.0$/, '')}${ing.unit}`;
  }

  // ── Audio beep ────────────────────────────────────────────────
  function playBeeps() {
    try {
      if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
      const beepAt = (t) => {
        const osc = audioCtx.createOscillator();
        const gain = audioCtx.createGain();
        osc.connect(gain);
        gain.connect(audioCtx.destination);
        osc.frequency.value = 880;
        osc.type = 'sine';
        gain.gain.setValueAtTime(0.3, t);
        gain.gain.exponentialRampToValueAtTime(0.001, t + 0.25);
        osc.start(t);
        osc.stop(t + 0.25);
      };
      const now = audioCtx.currentTime;
      beepAt(now);
      beepAt(now + 0.35);
      beepAt(now + 0.70);
    } catch(e) {}
  }

  // ── Timer ─────────────────────────────────────────────────────
  function updateTimerDisplay() {
    timerDisplay.textContent = fmtTime(timerSeconds);
    if (timerExpired) {
      timerDisplay.classList.add('cm-timer-expired');
    } else {
      timerDisplay.classList.remove('cm-timer-expired');
    }
  }

  function timerTick() {
    if (!timerRunning) return;
    if (timerSeconds > 0) {
      timerSeconds--;
      updateTimerDisplay();
    }
    if (timerSeconds === 0 && timerRunning) {
      timerRunning = false;
      timerExpired = true;
      clearInterval(timerInterval);
      timerInterval = null;
      timerDisplay.classList.add('cm-timer-expired');
      timerStartBtn.textContent = T.start;
      playBeeps();
      // Flash animation
      let flashes = 0;
      const flashInterval = setInterval(() => {
        timerDisplay.classList.toggle('cm-timer-flash');
        flashes++;
        if (flashes >= 6) clearInterval(flashInterval);
      }, 300);
    }
  }

  function setTimer(mins) {
    clearInterval(timerInterval);
    timerInterval = null;
    timerRunning = false;
    timerExpired = false;
    timerTarget = mins * 60;
    timerSeconds = timerTarget;
    timerStartBtn.textContent = T.start;
    updateTimerDisplay();
  }

  function initTimerUI() {
    timerLabel.textContent = T.timer;
    timerMinLabel.textContent = T.min;
    timerStartBtn.textContent = T.start;
    timerResetBtn.textContent = T.reset;

    document.querySelectorAll('.cm-preset-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const mins = parseInt(btn.dataset.mins);
        setTimer(mins);
        timerCustomInput.value = '';
        // Auto-start immediately
        timerExpired = false;
        timerRunning = true;
        timerStartBtn.textContent = T.pause;
        timerInterval = setInterval(timerTick, 1000);
      });
    });

    timerCustomInput.addEventListener('change', () => {
      const val = parseInt(timerCustomInput.value);
      if (val > 0) {
        setTimer(val);
        // Auto-start immediately
        timerExpired = false;
        timerRunning = true;
        timerStartBtn.textContent = T.pause;
        timerInterval = setInterval(timerTick, 1000);
      }
    });

    timerStartBtn.addEventListener('click', () => {
      if (timerSeconds === 0 && !timerRunning) return;
      timerExpired = false;
      timerDisplay.classList.remove('cm-timer-expired', 'cm-timer-flash');
      if (timerRunning) {
        timerRunning = false;
        clearInterval(timerInterval);
        timerInterval = null;
        timerStartBtn.textContent = T.start;
      } else {
        timerRunning = true;
        timerStartBtn.textContent = T.pause;
        timerInterval = setInterval(timerTick, 1000);
      }
    });

    timerResetBtn.addEventListener('click', () => {
      clearInterval(timerInterval);
      timerInterval = null;
      timerRunning = false;
      timerExpired = false;
      timerDisplay.classList.remove('cm-timer-expired', 'cm-timer-flash');
      timerSeconds = timerTarget;
      timerStartBtn.textContent = T.start;
      updateTimerDisplay();
    });

    // Mobile toggle
    timerToggleBtn.addEventListener('click', () => {
      if (!isMobile()) return;
      timerExpanded = !timerExpanded;
      timerBody.classList.toggle('cm-timer-body-visible', timerExpanded);
    });
  }

  // ── Prep mode ─────────────────────────────────────────────────
  function initPrepScreen() {
    prepDishName.textContent = dishName;
    prepBadge.textContent = T.prepMode;
    prepReadyLbl.textContent = T.prepReady;
    startCookBtn.textContent = T.startCooking;
    exitPrepBtn.textContent = T.exit;

    ingredientList.innerHTML = '';
    checkedCount = 0;

    ingredients.forEach((ing, idx) => {
      const li = document.createElement('li');
      li.className = 'cm-ingredient-item';

      const label = document.createElement('label');
      label.className = 'cm-ing-label';

      // Native checkbox (visually hidden, functionally active)
      const checkbox = document.createElement('input');
      checkbox.type = 'checkbox';
      checkbox.className = 'cm-ing-checkbox';
      checkbox.id = `cm-ing-${idx}`;

      // Custom visual checkbox
      const checkVis = document.createElement('span');
      checkVis.className = 'cm-ing-check-vis';
      checkVis.innerHTML = `<svg class="cm-check-icon" viewBox="0 0 12 10" fill="none">
        <polyline points="1,5 4.5,9 11,1" stroke="currentColor" stroke-width="2"
                  stroke-linecap="round" stroke-linejoin="round"/>
      </svg>`;

      // Name + note column
      const nameWrap = document.createElement('div');
      nameWrap.className = 'cm-ing-name-wrap';
      const nameSpan = document.createElement('span');
      nameSpan.className = 'cm-ing-name';
      nameSpan.textContent = ing.name;
      nameWrap.appendChild(nameSpan);
      if (ing.note) {
        const noteSpan = document.createElement('span');
        noteSpan.className = 'cm-ing-prep-note';
        noteSpan.textContent = ing.note;
        nameWrap.appendChild(noteSpan);
      }

      // Amount pill
      const amtSpan = document.createElement('span');
      amtSpan.className = 'cm-ing-amount';
      amtSpan.textContent = getScaledAmount(ing);

      checkbox.addEventListener('change', () => {
        if (checkbox.checked) {
          checkedCount++;
          li.classList.add('cm-ing-checked');
        } else {
          checkedCount--;
          li.classList.remove('cm-ing-checked');
        }
        updatePrepProgress();
      });

      label.appendChild(checkbox);
      label.appendChild(checkVis);
      label.appendChild(nameWrap);
      label.appendChild(amtSpan);
      li.appendChild(label);
      ingredientList.appendChild(li);
    });

    updatePrepProgress();
  }

  function updatePrepProgress() {
    const total = ingredients.length;
    const pct = total > 0 ? (checkedCount / total) * 100 : 0;
    prepProgress.innerHTML = `
      <div class="cm-prep-progress-row">
        <span class="cm-prep-count">${checkedCount} <span class="cm-prep-sep">/</span> ${total}</span>
        <span class="cm-prep-label">${T.prepReady}</span>
      </div>
      <div class="cm-prep-bar-wrap"><div class="cm-prep-bar" style="width:${pct}%"></div></div>`;
    const allDone = checkedCount === total && total > 0;
    startCookBtn.classList.toggle('cm-btn-glow', allDone);
  }

  // ── Cook mode ─────────────────────────────────────────────────
  function renderSteps() {
    stepsContainer.innerHTML = '';
    steps.forEach((step, idx) => {
      const div = document.createElement('div');
      div.className = 'cm-step-item';
      div.dataset.idx = String(idx);

      const numSpan = document.createElement('span');
      numSpan.className = 'cm-step-num';
      numSpan.textContent = `${idx + 1}`;

      const textDiv = document.createElement('div');
      textDiv.className = 'cm-step-text';
      textDiv.innerHTML = boldify(step);

      div.appendChild(numSpan);
      div.appendChild(textDiv);
      stepsContainer.appendChild(div);
    });
  }

  function updateCookDisplay() {
    const total = steps.length;
    if (total === 0) return;

    cookDishName.textContent = dishName;
    cookBadge.textContent = T.cookMode;
    stepCounter.textContent = `${T.step} ${currentStep + 1}${T.of}${total}`;
    stepDisplay.textContent = `${currentStep + 1} ${T.of} ${total}`;

    // Progress bar
    const pct = total > 1 ? (currentStep / (total - 1)) * 100 : 100;
    progressBar.style.width = `${pct}%`;

    // Update step visibility states
    const stepEls = stepsContainer.querySelectorAll('.cm-step-item');
    stepEls.forEach((el, idx) => {
      el.classList.remove('cm-step-current', 'cm-step-prev', 'cm-step-prev2',
                          'cm-step-next', 'cm-step-next2', 'cm-step-hidden');

      if (idx === currentStep) {
        el.classList.add('cm-step-current');
        el.setAttribute('aria-current', 'step');
      } else if (idx === currentStep - 1) {
        el.classList.add('cm-step-prev');
        el.removeAttribute('aria-current');
      } else if (idx < currentStep - 1) {
        el.classList.add('cm-step-prev2');
        el.removeAttribute('aria-current');
      } else if (idx === currentStep + 1) {
        el.classList.add('cm-step-next');
        el.removeAttribute('aria-current');
      } else if (idx === currentStep + 2) {
        el.classList.add('cm-step-next2');
        el.removeAttribute('aria-current');
      } else {
        el.classList.add('cm-step-hidden');
        el.removeAttribute('aria-current');
      }
    });

    // Scroll current step into view
    const currentEl = stepsContainer.querySelector('.cm-step-current');
    if (currentEl) {
      currentEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }

    // Nav buttons
    prevBtn.textContent = T.prev;
    prevBtn.disabled = currentStep === 0;

    if (currentStep >= total - 1) {
      nextBtn.textContent = T.done;
      nextBtn.classList.add('cm-btn-done');
    } else {
      nextBtn.textContent = T.next;
      nextBtn.classList.remove('cm-btn-done');
    }
    exitCookBtn.textContent = T.exit;
  }

  function goNext() {
    if (currentStep < steps.length - 1) {
      currentStep++;
      updateCookDisplay();
    } else {
      closeOverlay();
    }
  }

  function goPrev() {
    if (currentStep > 0) {
      currentStep--;
      updateCookDisplay();
    }
  }

  // ── Overlay open/close ────────────────────────────────────────
  function openOverlay() {
    overlay.hidden = false;
    // Force reflow for transition
    overlay.offsetHeight; // eslint-disable-line
    overlay.classList.add('cm-overlay-visible');
    document.body.classList.add('cm-body-lock');
    showPrepScreen();
  }

  function closeOverlay() {
    overlay.classList.remove('cm-overlay-visible');
    document.body.classList.remove('cm-body-lock');
    // Stop timer
    if (timerInterval) {
      clearInterval(timerInterval);
      timerInterval = null;
    }
    timerRunning = false;
    setTimeout(() => { overlay.hidden = true; }, 300);
  }

  function showPrepScreen() {
    prepScreen.hidden = false;
    cookScreen.hidden = true;
    initPrepScreen();
  }

  function showCookScreen() {
    prepScreen.hidden = true;
    cookScreen.hidden = false;
    currentStep = 0;
    renderSteps();
    updateCookDisplay();

    // Mobile timer starts collapsed
    if (isMobile()) {
      timerExpanded = false;
      timerBody.classList.remove('cm-timer-body-visible');
    } else {
      timerExpanded = true;
      timerBody.classList.add('cm-timer-body-visible');
    }
  }

  // ── Swipe support ─────────────────────────────────────────────
  function initSwipe() {
    const panel = document.getElementById('cm-steps-panel');
    panel.addEventListener('touchstart', (e) => {
      swipeStartX = e.touches[0].clientX;
    }, { passive: true });
    panel.addEventListener('touchend', (e) => {
      const dx = e.changedTouches[0].clientX - swipeStartX;
      if (Math.abs(dx) > 60) {
        if (dx < 0) goNext();
        else goPrev();
      }
    }, { passive: true });
  }

  // ── Keyboard ──────────────────────────────────────────────────
  function onKeydown(e) {
    if (overlay.hidden) return;
    if (!cookScreen.hidden) {
      if (e.key === 'ArrowRight' || e.key === ' ') { e.preventDefault(); goNext(); }
      else if (e.key === 'ArrowLeft') { e.preventDefault(); goPrev(); }
      else if (e.key === 'Escape') closeOverlay();
    } else if (!prepScreen.hidden) {
      if (e.key === 'Escape') closeOverlay();
    }
  }

  // ── Click on current step to advance ─────────────────────────
  function initStepClick() {
    stepsContainer.addEventListener('click', (e) => {
      const stepEl = e.target.closest('.cm-step-current');
      if (stepEl) goNext();
    });
  }

  // ── Init ──────────────────────────────────────────────────────
  function init() {
    initTimerUI();
    initSwipe();
    initStepClick();

    openBtn.addEventListener('click', openOverlay);
    exitPrepBtn.addEventListener('click', closeOverlay);
    exitCookBtn.addEventListener('click', closeOverlay);
    startCookBtn.addEventListener('click', showCookScreen);
    prevBtn.addEventListener('click', goPrev);
    nextBtn.addEventListener('click', goNext);

    document.addEventListener('keydown', onKeydown);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>

<style>
/* ── Entry button ──────────────────────────────────────────────── */
.cooking-mode-entry {
  margin: 16px 0 32px;
}

.cooking-mode-btn {
  background: var(--bg-elevated);
  border: 2px solid var(--accent);
  color: var(--accent);
  font-family: var(--font-mono);
  font-size: 1rem;
  font-weight: 700;
  padding: 10px 24px;
  border-radius: var(--radius);
  cursor: pointer;
  transition: background 0.15s, color 0.15s, box-shadow 0.15s;
  letter-spacing: 0.04em;
}

.cooking-mode-btn:hover {
  background: var(--accent);
