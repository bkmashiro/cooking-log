---
import Layout from '../../layouts/Layout.astro';
import SearchFilter from '../../components/SearchFilter.svelte';
import { getAllDishes } from '../../lib/dishes';
import { i18n, LANGS, CATEGORIES, TAGS, getCategoryLabel, getTagLabel, type Lang } from '../../lib/i18n';

export function getStaticPaths() {
  return LANGS.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = i18n[lang];
const dishes = getAllDishes();

// Serialize dish metadata for the client component
const dishMeta = dishes.map(d => ({
  name: d.recipe.dish[lang] || d.recipe.dish.zh,
  slug: d.slug,
  urlSlug: d.urlSlug,
  date: d.recipe.date,
  category: d.recipe.category ?? '',
  tags: d.recipe.tags ?? [],
}));

const categoryList = Object.keys(CATEGORIES).map(key => ({
  key,
  label: getCategoryLabel(key, lang),
}));

const tagList = Object.keys(TAGS).map(key => ({
  key,
  label: getTagLabel(key, lang),
}));

const langLinks = LANGS.map(l => ({ l, label: i18n[l].langName }));
---

<Layout lang={lang} title={t.allDishes}>
  <h1 class="page-title">{t.siteTitle}</h1>
  <p class="page-tagline">{t.tagline}</p>

  <div class="section-label">{t.allDishes}</div>

  <SearchFilter
    client:load
    dishes={dishMeta}
    lang={lang}
    t={{
      searchPlaceholder: t.searchPlaceholder,
      allCategories: t.allCategories,
      noResults: t.noResults,
      clearFilters: t.clearFilters,
    }}
    categories={categoryList}
    tags={tagList}
    langLinks={langLinks}
  />
</Layout>
